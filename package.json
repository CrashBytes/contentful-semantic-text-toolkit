{
  "name": "@crashbytes/semantic-text-toolkit",
  "version": "2.0.4",
  "description": "Production-grade semantic text analysis with embeddings, similarity, and vector operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "semantic",
    "embeddings",
    "text-analysis",
    "ml",
    "ai",
    "vector-search",
    "similarity",
    "nlp"
  ],
  "author": "Blackhole Software, LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrashBytes/contentful-semantic-text-toolkit.git"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "protobufjs": "7.6.4",
    "adm-zip": "0.6.0"
  }
}
